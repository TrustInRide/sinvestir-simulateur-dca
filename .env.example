# Optional — CoinGecko Demo API key (https://www.coingecko.com/en/api).
# Without it the public API is used (lower rate limit). The key is read
# server-side only (app/api/coingecko/*) and never exposed to the browser.
# Copy this file to `.env.local` and fill the value to enable it.
COINGECKO_API_KEY=

# Public URL of the deployed app (set after first Vercel deploy).
# Example: https://sinvestir-simulateur-crypto.vercel.app
NEXT_PUBLIC_SITE_URL=
